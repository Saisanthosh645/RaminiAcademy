# Firebase (optional — defaults in src/firebase/config.ts if unset)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Set to "true" to allow browser to seed empty `courses` collection (needs permissive rules or first-time setup)
# In production, omit or set false and seed via Admin SDK / Console — see docs/FIREBASE.md
# VITE_ENABLE_CLIENT_COURSE_SEED=true
